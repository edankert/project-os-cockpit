formulas:
  display_title: 'if(title, title, file.name)'
filters:
  and:
    - file.ext == "md"
    - type == "[[test]]"
    - not:
        - file.inFolder("__templates__")
        - file.inFolder(".trash")
        - file.inFolder(".obsidian")
properties:
  file.name:
    displayName: Note
  formula.display_title:
    displayName: Title
  id:
    displayName: ID
  status:
    displayName: Status
  scope:
    displayName: Scope
  level:
    displayName: Level
  validates:
    displayName: Validates
  last_run:
    displayName: Last run
  file.mtime:
    displayName: Updated
views:
  - type: table
    name: Failing
    filters: 'status == "failing"'
    order:
      - formula.display_title
      - scope
      - level
      - last_run
      - file.mtime
  - type: table
    name: All
    order:
      - formula.display_title
      - status
      - scope
      - level
      - last_run
      - file.mtime
    sort:
      - property: last_run
        direction: DESC
